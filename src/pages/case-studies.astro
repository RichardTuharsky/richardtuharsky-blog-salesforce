---
import RootLayout from "@/layouts/RootLayout.astro";
---

<RootLayout
  title="Case Studies"
  description="Real-world examples of technology and business transformation."
>
  <div class="divide-y divide-gray-200 dark:divide-gray-700">
    <div class="space-y-2 pb-8 pt-6 md:space-y-5">
      <h1
        class="text-3xl font-extrabold leading-9 tracking-tight text-gray-900 dark:text-gray-100 sm:text-4xl sm:leading-10 md:text-6xl md:leading-14"
      >
        Case Studies
      </h1>
      <p class="text-lg leading-7 text-gray-500 dark:text-gray-400">
        Real-world examples of technology and business transformation.
      </p>
    </div>
    <div class="py-12">
      <p class="text-gray-500 dark:text-gray-400">Case studies coming soon.</p>
    </div>
  </div>
</RootLayout>
