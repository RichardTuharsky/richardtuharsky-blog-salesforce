        <p class="text-xs pt-2" style="color: var(--color-muted-foreground);">Custom object configuration in Salesforce Schema Builder</p>
      </div>

      <h3 class="text-base font-bold mb-6 uppercase tracking-wider" style="color: var(--ink);">Standard Object Customisation</h3>

      <div class="mb-10">
        <h4 class="text-xs font-bold uppercase tracking-widest mb-3" style="color: var(--blue);">Account Object</h4>
