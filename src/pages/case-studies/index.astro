---
import RootLayout from "@/layouts/RootLayout.astro";
---

<RootLayout
  title="Case Studies"
  description="Real-world examples of technology and business transformation."
>
  <div class="divide-y divide-gray-200">
    <div class="space-y-2 pb-8 pt-6 md:space-y-5">
      <h1 class="text-3xl font-extrabold leading-9 tracking-tight text-gray-900 sm:text-4xl sm:leading-10 md:text-6xl md:leading-14">
        Case Studies
      </h1>
      <p class="text-lg leading-7 text-gray-500">
        Real-world examples of technology and business transformation.
      </p>
    </div>
    <div class="py-12 space-y-6">
      <a href="/case-studies/techgears" class="block group">
        <div class="border border-slate-200 p-6 editorial-shadow hover:border-slate-400 transition-colors">
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="text-xs px-2 py-1 font-medium uppercase tracking-wider" style="background-color: rgba(122,139,108,0.12); color: var(--sage);">Sales Cloud</span>
            <span class="text-xs px-2 py-1 font-medium uppercase tracking-wider" style="background-color: rgba(122,139,108,0.12); color: var(--sage);">Service Cloud</span>
            <span class="text-xs px-2 py-1 font-medium uppercase tracking-wider" style="background-color: rgba(122,139,108,0.12); color: var(--sage);">LWC</span>
            <span class="text-xs px-2 py-1 font-medium uppercase tracking-wider" style="background-color: rgba(122,139,108,0.12); color: var(--sage);">Apex</span>
          </div>
          <h2 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-blue-600 transition-colors">
            TechGears Ltd. — Complete Salesforce Implementation
          </h2>
          <p class="text-gray-500 text-sm leading-relaxed">
            Full-scale Salesforce implementation featuring custom objects, automation flows, Apex triggers, Lightning Web Components, and API integration for a mid-sized technology solutions company.
          </p>
          <div class="mt-4 text-sm font-medium" style="color: var(--persimmon);">Read case study →</div>
        </div>
      </a>
    </div>
  </div>
</RootLayout>
