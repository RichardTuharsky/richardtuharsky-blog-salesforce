---
import RootLayout from "@/layouts/RootLayout.astro";
---

<RootLayout
  title="Newsletter — Richard Tuharsky"
  description="Field notes from real Salesforce projects. Occasional notes on Sales Cloud, Service Cloud, Data Cloud, SFMC, and MuleSoft."
>
  <div class="py-10">

    <div class="mb-12" data-animate>
      <div class="inline-flex items-center gap-3 rounded-full border border-accent/30 bg-accent/5 px-5 py-2 mb-8">
        <span class="h-2 w-2 rounded-full bg-accent animate-pulse-soft"></span>
        <span class="font-mono text-xs uppercase tracking-[0.15em] text-accent">Newsletter</span>
      </div>

      <h1 class="font-display text-[2.5rem] sm:text-5xl leading-[1.08] tracking-[-0.02em] text-foreground mb-5 max-w-xl">
        Field notes from real Salesforce projects.
      </h1>
      <p class="text-lg text-muted-foreground leading-relaxed max-w-lg">
        Occasional notes on what works (and what doesn't) with Sales Cloud, Service Cloud, Data Cloud, SFMC, and MuleSoft in retail and services.
      </p>
    </div>

    <form
      id="subscribe-form"
      novalidate
      data-animate
    >
      <!-- Honeypot — hidden from real users, filled only by bots -->
      <div aria-hidden="true" class="sr-hidden">
        <label for="website">Leave this empty</label>
        <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
      </div>

      <div class="form-row">
        <div class="field">
          <label for="firstName">First name</label>
          <input
            type="text"
            id="firstName"
            name="firstName"
            placeholder="Jane"
            autocomplete="given-name"
          />
        </div>
        <div class="field">
          <label for="email">Email address <span aria-hidden="true"></span></label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="jane@company.com"
            required
            autocomplete="email"
          />
        </div>
      </div>

      <button type="submit" id="submit-btn">
        <span id="btn-label">Subscribe</span>
      </button>

      <p class="consent">
        No spam, ever. Unsubscribe any time, one click, no questions asked.
      </p>
    </form>

    <div
      id="form-message"
      role="status"
      aria-live="polite"
      aria-atomic="true"
      class="message hidden"
    ></div>

  </div>
</RootLayout>

<style>
  /* Honeypot — visually hidden but not display:none so bots render it */
  .sr-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  form {
    max-width: 540px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 0.75rem;
  }

  @media (max-width: 500px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-muted-foreground);
  }

  input[type="text"],
  input[type="email"] {
    height: 2.75rem;
    padding: 0 1rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    background: transparent;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-foreground);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    outline: none;
    width: 100%;
  }

  input::placeholder {
    color: color-mix(in srgb, var(--color-muted-foreground) 50%, transparent);
  }

  input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 12%, transparent);
  }

  button[type="submit"] {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    height: 2.75rem;
    padding: 0 1.75rem;
    border: none;
    border-radius: 0.75rem;
    background: linear-gradient(to right, var(--color-accent), var(--color-accent-secondary));
    color: var(--color-accent-foreground);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: opacity 0.15s ease, transform 0.15s ease;
    box-shadow: var(--shadow-accent);
  }

  button[type="submit"]:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: var(--shadow-accent-lg);
  }

  button[type="submit"]:active:not(:disabled) {
    transform: scale(0.98);
  }

  button[type="submit"]:disabled {
    opacity: 0.65;
    cursor: not-allowed;
  }

  .consent {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--color-muted-foreground);
    line-height: 1.6;
    margin-top: 0.25rem;
  }

  .message {
    max-width: 540px;
    margin-top: 1.25rem;
    padding: 0.9rem 1.1rem;
    border-radius: 0.75rem;
    font-size: 0.875rem;
    line-height: 1.5;
    font-family: var(--font-sans);
  }

  .message.hidden {
    display: none;
  }

  .message.success {
    background: color-mix(in srgb, #16a34a 8%, transparent);
    border: 1px solid color-mix(in srgb, #16a34a 25%, transparent);
    color: #15803d;
  }

  .message.error {
    background: color-mix(in srgb, #dc2626 8%, transparent);
    border: 1px solid color-mix(in srgb, #dc2626 25%, transparent);
    color: #b91c1c;
  }

  :global(.dark) .message.success { color: #4ade80; }
  :global(.dark) .message.error   { color: #f87171; }
</style>

<script>
  const form = document.getElementById('subscribe-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnLabel = document.getElementById('btn-label') as HTMLSpanElement;
  const messageEl = document.getElementById('form-message') as HTMLDivElement;

  function showMessage(text: string, type: 'success' | 'error') {
    messageEl.textContent = text;
    messageEl.className = `message ${type}`;
  }

  function setLoading(loading: boolean) {
    btn.disabled = loading;
    btnLabel.textContent = loading ? 'Subscribing…' : 'Subscribe';
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const data = new FormData(form);
    const email = (data.get('email') as string)?.trim();
    const firstName = (data.get('firstName') as string)?.trim();
    const website = (data.get('website') as string)?.trim();

    if (!email) {
      showMessage('Please enter your email address.', 'error');
      (form.querySelector('#email') as HTMLInputElement).focus();
      return;
    }

    setLoading(true);
    messageEl.className = 'message hidden';

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, firstName, website }),
      });

      const result = await res.json();

      if (result.success) {
        if (result.alreadySubscribed) {
          showMessage("You're already on the list — look out for the next issue.", 'success');
        } else {
          showMessage("You're in. Talk soon.", 'success');
          form.reset();
        }
      } else {
        showMessage(result.error ?? 'Something went wrong. Please try again.', 'error');
      }
    } catch {
      showMessage('Network error. Please check your connection and try again.', 'error');
    } finally {
      setLoading(false);
    }
  });
</script>
