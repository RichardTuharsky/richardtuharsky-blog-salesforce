---
import Link from "./Link.astro";
import { type CollectionEntry, getEntry } from "astro:content";

interface Props {
  tag?: CollectionEntry<"tags">;
  slug?: CollectionEntry<"tags">["id"];
}
let TagProp = Astro.props.tag;

if (!TagProp && Astro.props.slug) {
  TagProp = await getEntry("tags", Astro.props.slug);
}
---

{TagProp && (
  <Link
    href={`/tags/${TagProp.id}`}
    class="inline-flex items-center rounded-full border border-accent/20 bg-accent/5 px-3 py-0.5 font-mono text-[0.65rem] uppercase tracking-[0.1em] text-accent hover:bg-accent/10 hover:border-accent/40 transition-all duration-200"
  >
    {TagProp.data.name}
  </Link>
)}
