---
import { useTranslations } from "@/i18n";
const t = useTranslations();
---

<div class="flex items-center gap-1.5">
  <!-- Six-point asterisk mark -->
  <svg viewBox="0 0 20 20" width="16" height="16" fill="none" aria-hidden="true" class="text-foreground shrink-0" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
    <line x1="10" y1="2"   x2="10" y2="18"/>
    <line x1="2.7" y1="6"  x2="17.3" y2="14"/>
    <line x1="17.3" y1="6" x2="2.7"  y2="14"/>
  </svg>

  <span class="text-xl font-bold tracking-tight text-foreground">
    {t("siteMetadata.headerTitle")}
  </span>
</div>
