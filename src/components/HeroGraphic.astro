---
// All animations are scoped in the <style> block below — no Tailwind animation utilities needed
---

<div
  class="relative w-full max-w-[480px] mx-auto aspect-square select-none"
  aria-hidden="true"
>
  <!-- Dot grid -->
  <div
    class="absolute inset-0"
    style="background-image: radial-gradient(circle, rgb(0 82 255 / 0.14) 1px, transparent 1px); background-size: 28px 28px;"
  ></div>

  <!-- Radial glow -->
  <div
    class="absolute inset-0"
    style="background: radial-gradient(circle at 50% 50%, rgb(0 82 255 / 0.08) 0%, transparent 65%);"
  ></div>

  <!-- Rotating dashed outer ring -->
  <div class="absolute inset-3 rounded-full border-2 border-dashed border-accent/25 hero-spin"></div>

  <!-- Counter-rotating inner ring -->
  <div class="absolute inset-16 rounded-full border border-accent/20 hero-spin-reverse"></div>

  <!-- Central hub -->
  <div class="absolute inset-0 flex items-center justify-center">
    <div class="relative">
      <div
        class="w-20 h-20 rounded-full flex items-center justify-center"
        style="background: linear-gradient(135deg, var(--color-accent), var(--color-accent-secondary)); box-shadow: 0 8px 32px rgb(0 82 255 / 0.45);"
      >
        <svg viewBox="0 0 24 24" class="w-9 h-9" fill="white">
          <path d="M19.35 10.04A7.49 7.49 0 0012 4C9.11 4 6.6 5.64 5.35 8.04A5.994 5.994 0 000 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z"/>
        </svg>
      </div>
      <!-- Pulse ring around hub -->
      <div
        class="absolute -inset-3 rounded-full border-2 border-accent/40 hero-pulse"
      ></div>
      <div
        class="absolute -inset-6 rounded-full border border-accent/15 hero-pulse"
        style="animation-delay: -1s;"
      ></div>
    </div>
  </div>

  <!-- Card: Leads (top-left) -->
  <div class="absolute top-[9%] left-[1%] hero-float" style="animation-delay: 0s;">
    <div class="bg-card border border-border rounded-xl px-3.5 py-2.5 shadow-lg min-w-[118px]">
      <div class="flex items-center gap-2 mb-1.5">
        <div class="w-5 h-5 rounded-md flex items-center justify-center shrink-0" style="background: linear-gradient(135deg, var(--color-warm), var(--color-warm-secondary));">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <span class="font-mono text-[0.58rem] uppercase tracking-widest text-muted-foreground">Leads</span>
      </div>
      <p class="font-display text-xl text-foreground leading-none">247</p>
      <p class="font-mono text-[0.58rem] mt-0.5" style="color: #16a34a;">↑ 18% this month</p>
    </div>
  </div>

  <!-- Card: Pipeline (top-right) -->
  <div class="absolute top-[5%] right-[0%] hero-float" style="animation-delay: -1.8s;">
    <div class="bg-card border border-border rounded-xl px-3.5 py-2.5 shadow-lg min-w-[126px]">
      <div class="flex items-center gap-2 mb-1.5">
        <div class="w-5 h-5 rounded-md flex items-center justify-center shrink-0" style="background: linear-gradient(135deg, var(--color-warm), var(--color-warm-secondary));">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
          </svg>
        </div>
        <span class="font-mono text-[0.58rem] uppercase tracking-widest text-muted-foreground">Pipeline</span>
      </div>
      <p class="font-display text-xl text-foreground leading-none">$2.4M</p>
      <p class="font-mono text-[0.58rem] text-muted-foreground mt-0.5">Q2 on track</p>
    </div>
  </div>

  <!-- Card: CSAT (bottom-left) -->
  <div class="absolute bottom-[10%] left-[0%] hero-float" style="animation-delay: -3.2s;">
    <div class="bg-card border border-border rounded-xl px-3.5 py-2.5 shadow-lg min-w-[118px]">
      <div class="flex items-center gap-2 mb-1.5">
        <div class="w-5 h-5 rounded-md flex items-center justify-center shrink-0" style="background: linear-gradient(135deg, var(--color-warm), var(--color-warm-secondary));">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
          </svg>
        </div>
        <span class="font-mono text-[0.58rem] uppercase tracking-widest text-muted-foreground">CSAT</span>
      </div>
      <p class="font-display text-xl text-foreground leading-none">94%</p>
      <p class="font-mono text-[0.58rem] mt-0.5" style="color: #16a34a;">↑ Satisfaction</p>
    </div>
  </div>

  <!-- Card: Cases (bottom-right) -->
  <div class="absolute bottom-[6%] right-[1%] hero-float" style="animation-delay: -0.6s;">
    <div class="bg-card border border-border rounded-xl px-3.5 py-2.5 shadow-lg min-w-[118px]">
      <div class="flex items-center gap-2 mb-1.5">
        <div class="w-5 h-5 rounded-md flex items-center justify-center shrink-0" style="background: linear-gradient(135deg, var(--color-warm), var(--color-warm-secondary));">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <span class="font-mono text-[0.58rem] uppercase tracking-widest text-muted-foreground">Cases</span>
      </div>
      <p class="font-display text-xl text-foreground leading-none">98%</p>
      <p class="font-mono text-[0.58rem] text-muted-foreground mt-0.5">Resolution rate</p>
    </div>
  </div>

  <!-- Decorative dots -->
  <div class="absolute top-[37%] right-[5%] w-2.5 h-2.5 rounded-sm hero-pulse" style="background: linear-gradient(135deg, var(--color-accent), var(--color-accent-secondary)); animation-delay: -0.5s;"></div>
  <div class="absolute bottom-[37%] left-[6%] w-2 h-2 rounded-sm hero-pulse" style="background: var(--color-accent); opacity: 0.5; animation-delay: -1.5s;"></div>
</div>

<style>
  @keyframes hfloat {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-13px); }
  }
  @keyframes hspin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  @keyframes hspinr {
    from { transform: rotate(0deg); }
    to   { transform: rotate(-360deg); }
  }
  @keyframes hpulse {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50%       { opacity: 0.9; transform: scale(1.08); }
  }

  .hero-float   { animation: hfloat 4s ease-in-out infinite; }
  .hero-spin    { animation: hspin  25s linear infinite; }
  .hero-spin-reverse { animation: hspinr 18s linear infinite; }
  .hero-pulse   { animation: hpulse 2.5s ease-in-out infinite; }

  @media (prefers-reduced-motion: reduce) {
    .hero-float, .hero-spin, .hero-spin-reverse, .hero-pulse { animation: none; }
  }
</style>
